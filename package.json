{
  "name": "neuevault",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite --port 4173",
    "build:vite": "vite build",
    "build": "npm run build:vite && node scripts/generate-cache-headers.mjs && npm run audit:cache-headers",
    "test": "vitest run",
    "test:e2e": "playwright test",
    "generate:assets": "node scripts/generate-assets.mjs",
    "validate:assets": "node scripts/validate-assets.mjs",
    "clean:generated": "node scripts/clean-generated.mjs",
    "cloudinary:sync": "node scripts/cloudinary-sync.mjs",
    "cloudinary:verify": "node scripts/cloudinary-verify.mjs",
    "cloudinary:prune": "node scripts/cloudinary-prune.mjs",
    "audit:cloudinary-secrets": "node scripts/audit-cloudinary-secrets.mjs",
    "audit:bundle": "node scripts/audit-bundle.mjs",
    "audit:cache-headers": "node scripts/audit-cache-headers.mjs",
    "assets:update": "node scripts/assets-update.mjs",
    "manage:content": "node scripts/manage-content.mjs",
    "pages:dev": "npm run build && wrangler pages dev dist"
  },
  "devDependencies": {
    "@playwright/test": "^1.54.1",
    "cloudinary": "^2.10.0",
    "rollup-plugin-visualizer": "^6.0.3",
    "sharp": "^0.35.3",
    "vite": "^7.0.5",
    "vitest": "^3.2.4",
    "wrangler": "^4.25.0",
    "zod": "^4.0.5"
  },
  "dependencies": {
    "lenis": "^1.3.25"
  }
}
